  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Regular",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["12", "--display"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tetris",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["19", "--display"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tetris Debug",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["19", "--display", "--debug", "--verbose"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Mario",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["20", "--display"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Red",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["13", "--display"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["2", "--debug"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Verbose",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["2", "--debug", "--verbose"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Regular No Display",
      "program": "${workspaceFolder}/zig-out/bin/gameboy",
      "args": ["2"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
